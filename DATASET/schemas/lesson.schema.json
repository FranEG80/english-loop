{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://englishloop.local/schemas/lesson.schema.json",
  "title": "EnglishLoop lesson frontmatter",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "id",
    "title",
    "level",
    "category",
    "topic",
    "subtopics",
    "difficulty",
    "estimatedMinutes",
    "learningObjectives",
    "prerequisites",
    "frameworkRefs",
    "relatedLessonIds",
    "tags",
    "status",
    "author",
    "reviewer",
    "contentVersion"
  ],
  "properties": {
    "schemaVersion": { "const": "1.0.0" },
    "id": { "$ref": "#/$defs/id" },
    "title": { "type": "string", "minLength": 5, "maxLength": 120 },
    "level": { "enum": ["B1", "B2"] },
    "category": { "$ref": "#/$defs/id" },
    "topic": { "$ref": "#/$defs/id" },
    "subtopics": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/id" }
    },
    "difficulty": { "type": "integer", "minimum": 1, "maximum": 5 },
    "estimatedMinutes": { "type": "integer", "minimum": 5, "maximum": 90 },
    "learningObjectives": {
      "type": "array",
      "minItems": 2,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 12 }
    },
    "prerequisites": {
      "type": "array",
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/id" }
    },
    "frameworkRefs": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 3 }
    },
    "relatedLessonIds": {
      "type": "array",
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/id" }
    },
    "tags": {
      "type": "array",
      "minItems": 2,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/id" }
    },
    "status": { "enum": ["draft", "reviewed", "published"] },
    "author": { "type": "string", "minLength": 2 },
    "reviewer": { "type": "string", "minLength": 2 },
    "contentVersion": { "type": "integer", "minimum": 1 }
  },
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    }
  }
}
