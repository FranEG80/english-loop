{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://englishloop.local/schemas/coverage.schema.json",
  "title": "EnglishLoop coverage targets",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "global", "nodes"],
  "properties": {
    "schemaVersion": { "const": "1.0.0" },
    "global": {
      "type": "object",
      "additionalProperties": false,
      "required": ["minimumLessons", "minimumActivities"],
      "properties": {
        "minimumLessons": { "type": "integer", "minimum": 100 },
        "minimumActivities": { "type": "integer", "minimum": 10000 }
      }
    },
    "nodes": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "taxonomyNodeId",
          "level",
          "minimumActivities",
          "minimumActivityTypes",
          "requiredDifficulties"
        ],
        "properties": {
          "taxonomyNodeId": {
            "type": "string",
            "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
          },
          "level": { "enum": ["B1", "B2"] },
          "minimumActivities": { "type": "integer", "minimum": 1 },
          "minimumActivityTypes": { "type": "integer", "minimum": 1 },
          "requiredDifficulties": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": { "type": "integer", "minimum": 1, "maximum": 5 }
          }
        }
      }
    }
  }
}
